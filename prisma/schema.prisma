generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id            String   @id
  name          String
  status        String   @default("queued") // queued, running, completed, failed
  query         Json // { locationText, radiusKm, businessTypes[] }
  
  // Counters
  placesDiscovered  Int  @default(0)
  websitesScraped   Int  @default(0)
  leadsEnriched     Int  @default(0)
  leadsTotal        Int  @default(0)
  
  // Error handling
  errorMessage  String?
  
  // Relationships
  leads         Lead[]
  exports       Export[]
  activity      ActivityEvent[]
  
  // Metadata
  createdBy     String   @default("admin")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastRunAt     DateTime?

  @@index([status])
  @@index([createdAt])
}

model Lead {
  id              String   @id
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  // Business info
  placeId         String?
  businessName    String
  contactName     String?
  category        String?
  
  // Location
  address         String?
  city            String?
  state           String?
  country         String   @default("USA")
  
  // Contact info
  phone           String?
  email           String?
  emailVerified   Boolean  @default(false)
  website         String?
  
  // Ratings & scoring
  rating          Float?
  reviewCount     Int      @default(0)
  score           Float    @default(0)
  icpMatch        Boolean  @default(false)
  
  // Metadata
  source          String   @default("google_places")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([jobId])
  @@index([email])
  @@index([score])
}

model Export {
  id              String   @id
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  format          String   @default("csv")
  filterSummary   String   @default("")
  rowCount        Int      @default(0)
  status          String   @default("ready")
  downloadUrl     String?
  
  createdAt       DateTime @default(now())

  @@index([jobId])
}

model ActivityEvent {
  id        String   @id
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  type      String   // "job_created", "discovery_started", etc
  message   String
  timestamp DateTime @default(now())

  @@index([jobId])
}
