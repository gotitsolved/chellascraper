# Google Places API for location-based business search
# Get key from: https://cloud.google.com/maps-platform
GOOGLE_PLACES_API_KEY=

# Email verification and contact extraction
# Optional: configure for enhanced email verification and SMTP testing
VERIFIER_IO_API_KEY=

# Optional: AI Gateway API key for advanced lead scoring
# Leave empty to use default Vercel AI Gateway models
AI_GATEWAY_API_KEY=

# Custom scraping configuration
# Set to true to enable website scraping; requires a web scraper (e.g., Browserless, ScraperAPI)
ENABLE_WEBSITE_SCRAPING=false
WEBSITE_SCRAPER_API_KEY=

# Google OAuth configuration (optional, for future auth flows)
GOOGLE_CLIENT_ID=4555736497-h2slovts2srgj434petl1fsagknnst5l.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
